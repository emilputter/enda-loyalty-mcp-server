# ENDA MCP Server configuration
# Copy this file to `.env` and replace the example values.

# Base URL of the ENDA Loyalty REST API. Keep the `/api/v1` path suffix.
ENDA_API_BASE_URL=https://api.hederacourt.site/api/v1

# The API contract used to generate MCP tools at startup. Optional: this is
# the default when the variable is not set.
ENDA_OPENAPI_URL=https://api.hederacourt.site/v3/api-docs

# Keycloak configuration for staff authentication.
ENDA_KEYCLOAK_BASE=https://keycloak.example.com
ENDA_KEYCLOAK_REALM=my-enda
ENDA_KEYCLOAK_ID=test-client

# OAuth callback address. This must match the Keycloak client configuration.
ENDA_REDIRECT_URI=http://127.0.0.1:8000
