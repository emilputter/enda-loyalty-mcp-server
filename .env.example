# ENDA MCP Server configuration
# Copy this file to `.env` and fill in real values before running.
# (`.env` is gitignored; `.env.example` is committed as a template.)

# Base URL of the ENDA Loyalty backend REST API.
ENDA_API_BASE_URL=https://your-enda-api-host

# Base URL of the Keycloak instance used for authentication.
ENDA_KEYCLOAK_BASE=https://your-keycloak-host

# Keycloak realm the ENDA client belongs to.
ENDA_KEYCLOAK_REALM=your-realm

# Keycloak client (application) ID.
ENDA_KEYCLOAK_ID=your-client-id

# OAuth2 redirect URI. MUST be http://127.0.0.1:8000 — that is the
# address the local callback listener binds to during login.
# The Keycloak client must be configured to allow this redirect URI.
ENDA_REDIRECT_URI=http://127.0.0.1:8000
