# Example configuration for the ENDA Loyalty MCP server
# Copy this file to ".env" and replace example values to what your using

# ENDA Backend API
API_BASE_URL=https://api.example.com

# Keycloak Configuration
KEYCLOAK_BASE=https://keycloak.example.com
KEYCLOAK_REALM=my-enda
KEYCLOAK_CLIENT_ID=test-client

# OAuth Redirect URI
REDIRECT_URI=http://127.0.0.1:8000/callback